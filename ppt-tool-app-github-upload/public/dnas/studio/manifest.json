{
  "schema_version": "1.2",
  "_usage": {
    "本文档作用": "描述 Studio DNA 的全部 40 个 variant。供 visual-planner skill 在为 PPT 每一页选 variant 时查询。",
    "消费方": [
      "visual-planner skill: 根据每页 page_role 和内容特征, 从 variants 数组挑一个最合适的 variant",
      "css-renderer skill: 拿到 variant_id 后, 通过 _renderer.dom_selector 在 skeleton 找 DOM, 按 slots 填内容"
    ],
    "选 variant 的标准步骤": [
      "1. 读 planning.md 这一页的 page_role(必须是 12 个标准值之一)",
      "2. 在 variants 数组里筛选所有 page_role 匹配的 variant",
      "3. 对比每个候选 variant 的 \"什么时候用\" 字段, 根据内容特征选最合适",
      "4. 检查 \"数量约束\", 确保内容项数符合 variant 容量",
      "5. 不符合, 查 \"什么时候不用\" 数组找 fallback variant"
    ],
    "输出格式": "选定 variant 后, 按 _yaml_example_text 格式输出 visual_plan.yaml",
    "禁止行为": [
      "不要编造 manifest 中不存在的 variant_id",
      "不要编造 manifest 中不存在的 slot key",
      "不要使用下划线前缀字段(_renderer, _warnings) 作为业务字段",
      "如果所有 variant 都不合适, 在 yaml 的 review_comments 里如实说明, 不要硬塞"
    ]
  },
  "_type_definitions": {
    "纯文本": {
      "格式": "字符串, 不含任何 HTML 标签",
      "示例": "2025 中国新能源汽车年度观察",
      "禁止": [
        "<em>...</em>",
        "<br>",
        "**markdown**"
      ]
    },
    "富文本": {
      "格式": "字符串, 允许以下 HTML 标签",
      "允许的标签": {
        "<em>...</em>": "用主题 accent 色高亮关键词",
        "<strong>...</strong>": "加粗强调",
        "<br>": "换行(只在标题类 slot 用)",
        "<span class='accent-word'>...</span>": "强调词(同 accent 色)",
        "<span class='outline-word'>...</span>": "空心描边字(大字版用)",
        "<span class='unit'>...</span>": "数字后小单位"
      },
      "示例": "渗透率<em>40.9%</em>的历史性拐点",
      "禁止": [
        "除上述外的 HTML 标签",
        "嵌套 HTML",
        "markdown 语法"
      ]
    },
    "组合字段": {
      "格式": "JSON 对象, 有多个固定子字段",
      "示例": {
        "label": "市场规模",
        "value": "1285万辆"
      },
      "说明": "每个子字段在 variant 的 slots 定义里详细说明"
    },
    "同质列表": {
      "格式": "JSON 数组, 每项是字符串",
      "示例": [
        "渗透率突破 40%",
        "出口同比 +71%",
        "动力电池 TOP3 中国占 2"
      ],
      "说明": "用于一组同类型简单项"
    },
    "重复列表": {
      "格式": "JSON 对象数组, 每项是一个对象",
      "示例": [
        {
          "item-label": "DRIVER 01",
          "item-title": "渗透率拐点",
          "item-desc": "..."
        },
        {
          "item-label": "DRIVER 02",
          "item-title": "自主份额",
          "item-desc": "..."
        }
      ],
      "说明": "用于一组异质项, 每项含多字段。featured 项用 _featured: true 标记"
    },
    "图片": {
      "格式": "JSON 对象",
      "示例": {
        "url": "https://picsum.photos/seed/cars/1280/720",
        "alt": "新能源车流",
        "image_fit": "cover"
      },
      "image_fit 枚举值": {
        "cover": "填满容器, 居中裁切, 不变形 - 适合摄影 / 风景",
        "contain": "完整显示, 周围 padding - 适合产品图 / logo",
        "scale-down": "不放大失真, 居中显示 - 适合截图 / 小尺寸"
      },
      "url 留空时": "用骨架默认渐变背景(各主题自适应)"
    },
    "图表": {
      "格式": "JSON 对象",
      "示例": {
        "type": "line",
        "x_labels": [
          "Q1",
          "Q2",
          "Q3",
          "Q4"
        ],
        "primary": {
          "label": "销量(万辆)",
          "data": [
            25,
            32,
            42,
            50
          ]
        }
      },
      "type 枚举值 (封闭)": [
        "line",
        "bar",
        "bar-line-combo",
        "doughnut",
        "pie"
      ],
      "禁止": "不要用枚举外的类型, 渲染器没桥接会画空白"
    }
  },
  "_fallback_rules": {
    "内容项数超过最多": {
      "处理": "拆成两页, 第二页用相同 variant",
      "示例": "用户给 8 条要点, S-D 严格 4 个 → 拆 2 页 S-D 或改用 S-E"
    },
    "内容项数少于最少": {
      "处理": "查 variant '什么时候不用' 数组, 跟随建议",
      "示例": "2 条数据, S-A 需要 3 条 → S-A '什么时候不用' 指明退路"
    },
    "找不到匹配 page_role 的 variant": {
      "处理": "退到 page_role=support, 在 review_comments 里说明",
      "禁止": "不要编造 variant_id"
    },
    "用户内容跟所有 variant 都不匹配": {
      "处理": "在 yaml 的 global.review_comments 里如实说明",
      "禁止": "不要硬塞内容到不合适的 variant"
    },
    "字数超过 slot 最大字数": {
      "处理": "精简内容到限制内",
      "底线": "不能为了塞内容而违反字数限制"
    }
  },
  "_yaml_example_text": "# Studio DNA · visual_plan.yaml 示例\n\nglobal:\n  dna: \"studio\"\n  total_pages: 20\n  review_comments: |\n    20 页, 17 个不同 variant\n    高潮: 2 个 climax (P2 CLX-A · 40.9%, P8 CLX-C · 双数字)\n    Gallery: 1 个 (P10 H3)\n\npages:\n  - slide: 1\n    variant_id: \"COV-A\"\n    page_role: \"cover\"\n    director_note: |\n      【情绪定调】权威庄重\n      【内容载体】全出血图 + 左下文字\n      【视觉主角】slot-title-zh 中文主标\n      【空间分配】骨架默认\n      【演讲配合】无动画\n    slots:\n      slot-eyebrow: \"[ ANNUAL OBSERVATION · 2025 ]\"\n      slot-title-en: \"THE YEAR OF<br>EXECUTION\"\n      slot-title-zh: \"2025 中国新能源汽车<em>年度观察</em>\"\n      slot-cover-meta:\n        - \"DATA-DRIVEN · APRIL 2026\"\n        - \"60 PAGES · 32 CHARTS\"\n        - \"BY ARCHIVE RESEARCH\"\n      img-full:\n        url: \"https://picsum.photos/seed/ev-highway/1280/720\"\n        alt: \"新能源汽车高速车流\"\n        image_fit: \"cover\"\n\n  - slide: 4\n    variant_id: \"S-A\"\n    page_role: \"support\"\n    director_note: |\n      【情绪定调】冷静客观\n      【内容载体】左折线图 + 右 3 条增长驱动力\n      【视觉主角】左侧折线图\n      【空间分配】7:3 强调图表\n      【演讲配合】图表先出, 三条要点依次淡入\n    slots:\n      slot-title-en: \"GROWTH<br>DRIVERS\"\n      slot-title-zh: \"核心增长驱动力分析\"\n      slot-chart:\n        type: \"line\"\n        x_labels: [\"Q1\", \"Q2\", \"Q3\", \"Q4\", \"Q5\", \"Q6\", \"Q7\"]\n        primary: {label: \"月度销量(万辆)\", data: [25, 32, 38, 42, 50, 58, 65]}\n        fill: true\n      slot-item-list:\n        - item-label: \"[ DRIVER 01 ]\"\n          item-title: \"渗透率突破拐点\"\n          item-desc: \"年渗透率从 28% 跃升至 40.9%。\"\n        - item-label: \"[ DRIVER 02 ]\"\n          item-title: \"自主品牌份额\"\n          item-desc: \"TOP5 自主份额达 67%。\"\n        - item-label: \"[ DRIVER 03 ]\"\n          item-title: \"出口成第二曲线\"\n          item-desc: \"2024 年出口 127 万辆, 同比 +71%。\"\n      slot-source: \"数据来源: 中汽协, 2026.03\"\n",
